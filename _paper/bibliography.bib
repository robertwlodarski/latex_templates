@article{kalemli-ozcan_how_2024,
	title = {How to {Construct} {Nationally} {Representative} {Firm}-{Level} {Data} from the {Orbis} {Global} {Database}: {New} {Facts} on {SMEs} and {Aggregate} {Implications} for {Industry} {Concentration}},
	volume = {16},
	issn = {1945-7707, 1945-7715},
	shorttitle = {How to {Construct} {Nationally} {Representative} {Firm}-{Level} {Data} from the {Orbis} {Global} {Database}},
	url = {https://pubs.aeaweb.org/doi/10.1257/mac.20220036},
	doi = {10.1257/mac.20220036},
	abstract = {We construct nationally representative firm-level longitudinal data for European countries using financial statements from the Orbis database. We validate our data by comparing its coverage and firm size distribution to official statistics. We showcase two applications to show the importance of firm representativeness in understanding macroeconomic outcomes. First, we show that small and medium-sized firms account for a large share of aggregate economic activity. Second, we document that firm representativeness is important for calculating industry concentration trends over time as the share of economic activity accounted by top firms in an industry changes with the firm samples used. (JEL C81, D22, G30, L11, L25, L60)},
	language = {en},
	number = {2},
	urldate = {2025-12-16},
	journal = {American Economic Journal: Macroeconomics},
	author = {Kalemlİ-Özcan, Şebnem and Sørensen, Bent E. and Villegas-Sanchez, Carolina and Volosovych, Vadym and Yeşiltaş, Sevcan},
	month = apr,
	year = {2024},
	pages = {353--374},
}
